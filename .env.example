# Booking Service environment example
# Copy this file to .env and fill in your values. Do not commit real secrets.

# Spring profile
# local: stub clients and security disabled by default
# dev/prod: deployed environment placeholders until external API contracts are finalized
SPRING_PROFILES_ACTIVE=local

# Application port
SERVER_PORT=8081

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/booking_db
DB_USERNAME=booking_user
DB_PASSWORD=change-me

# Security switch
# Set false for local development when authentication is handled outside the service.
SECURITY_ENABLED=false

# JWT validation
JWT_ISSUER=cargo-platform
JWT_AUDIENCE=equipments-service
JWT_SECRET=change-me-to-at-least-256-bits-for-hs256
JWT_EXPIRATION=3600000

# Backward-compatible JWT aliases accepted by application config
AUTH_JWT_ISSUER=cargo-platform
AUTH_JWT_AUDIENCE=equipments-service
AUTH_JWT_SECRET=change-me-to-at-least-256-bits-for-hs256

# CORS
# Comma-separated list consumed by Spring configuration binding.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# External integration placeholders
# Real client implementations are intentionally deferred until external API contracts are finalized.
SCHEDULE_API_URL=http://localhost:8082
SCHEDULE_API_TIMEOUT=5000
EQUIPMENT_API_URL=http://localhost:8083
EQUIPMENT_API_TIMEOUT=5000
QUOTE_API_URL=http://localhost:8084
QUOTE_API_TIMEOUT=5000
